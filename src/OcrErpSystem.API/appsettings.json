{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=ocrerp;Username=app;Password=changeme"
  },
  "Acumatica": {
    "BaseUrl": "https://your-acumatica-instance.com",
    "ApiVersion": "23.200.001",
    "Authority": "https://your-acumatica-instance.com/identity",
    "Audience": "ocr-erp-api",
    "ServiceAccount": {
      "ClientId": "your-client-id",
      "ClientSecret": "your-client-secret"
    }
  },
  "Storage": {
    "Type": "local",
    "LocalPath": "/data/documents",
    "BaseUrl": "http://localhost:5000/files"
  },
  "Tesseract": {
    "DataPath": "/usr/share/tessdata",
    "Language": "eng"
  },
  "AllowedOrigins": [
    "http://localhost:5173"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
