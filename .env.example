# ── Database ────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Acumatica ERP ───────────────────────────────────────────────────────
ACUMATICA_URL=https://your-acumatica.example.com
ACUMATICA_API_VERSION=23.200.001
ACUMATICA_CLIENT_ID=your-oauth-client-id

# ── Acumatica private_key_jwt client assertion (RSA key components) ─────
# Generate an RSA-2048 key pair. Register ONLY the public key (N + E) in the
# Acumatica Connected Application. Store all components here (private key stays server-side).
ACUMATICA_CA_N=base64url-encoded-modulus
ACUMATICA_CA_E=AQAB
ACUMATICA_CA_D=base64url-encoded-private-exponent
ACUMATICA_CA_P=base64url-encoded-prime-p
ACUMATICA_CA_Q=base64url-encoded-prime-q
ACUMATICA_CA_DP=base64url-encoded-dp
ACUMATICA_CA_DQ=base64url-encoded-dq
ACUMATICA_CA_QI=base64url-encoded-qi

# ── Storage ─────────────────────────────────────────────────────────────
# A random 64-char hex string used to sign document download URLs
STORAGE_SIGNING_KEY=replace_with_64_char_random_hex

# ── URLs ────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ── Hangfire dashboard ───────────────────────────────────────────────────
HANGFIRE_USER=admin
HANGFIRE_PASSWORD=change_me_strong_password

# ── Demo mode — set true only when no Acumatica instance is available ───
DEMO_ENABLED=false
DEMO_SIGNING_KEY=
