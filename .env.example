# ── Database ────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Acumatica ERP ───────────────────────────────────────────────────────
ACUMATICA_URL=https://your-acumatica.example.com
ACUMATICA_API_VERSION=24.200.001
ACUMATICA_CLIENT_ID=your-oauth-client-id@Your Company Name
ACUMATICA_CLIENT_SECRET=your-client-secret

# ── Acumatica private_key_jwt client assertion (RSA key components) ─────
# Generate an RSA-2048 key pair. Register ONLY the public key (N + E) in the
# Acumatica Connected Application. Store all components here (private key stays server-side).
ACUMATICA_CA_N=base64url-encoded-modulus
ACUMATICA_CA_E=AQAB
ACUMATICA_CA_D=base64url-encoded-private-exponent
ACUMATICA_CA_P=base64url-encoded-prime-p
ACUMATICA_CA_Q=base64url-encoded-prime-q
ACUMATICA_CA_DP=base64url-encoded-dp
ACUMATICA_CA_DQ=base64url-encoded-dq
ACUMATICA_CA_QI=base64url-encoded-qi

# ── Storage ─────────────────────────────────────────────────────────────
# A random 64-char hex string used to sign document download URLs
STORAGE_SIGNING_KEY=replace_with_64_char_random_hex

# ── URLs ────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ── Hangfire dashboard ───────────────────────────────────────────────────
HANGFIRE_USER=admin
HANGFIRE_PASSWORD=change_me_strong_password

# ── Anthropic Claude OCR (optional) ─────────────────────────────────────
# When set, Claude Vision API is used instead of Tesseract for OCR.
# Leave blank to keep using the built-in Tesseract engine.
ANTHROPIC_API_KEY=
ANTHROPIC_PRIMARY_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6

# ── Own company names (vendor-name OCR exclusion) ───────────────────────
# Semicolon-separated list of your own company name variants.
# If OCR extracts one of these as the vendor name, validation will fail
# and prompt the user to correct the field.
OWN_COMPANY_NAMES=Geohan Sdn Bhd;Geohan;GEOHAN SDN BHD

# ── Demo mode — set true only when no Acumatica instance is available ───
DEMO_ENABLED=false
DEMO_SIGNING_KEY=
