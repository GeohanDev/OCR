# Stage 1 — build
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy solution and project files first (layer cache for restore)
COPY OcrSystem.sln ./
COPY src/OcrSystem.Common/OcrSystem.Common.csproj             src/OcrSystem.Common/
COPY src/OcrSystem.Domain/OcrSystem.Domain.csproj             src/OcrSystem.Domain/
COPY src/OcrSystem.Application/OcrSystem.Application.csproj   src/OcrSystem.Application/
COPY src/OcrSystem.OCR/OcrSystem.OCR.csproj                   src/OcrSystem.OCR/
COPY src/OcrSystem.Infrastructure/OcrSystem.Infrastructure.csproj src/OcrSystem.Infrastructure/
COPY src/OcrSystem.API/OcrSystem.API.csproj                   src/OcrSystem.API/

RUN dotnet restore src/OcrSystem.API/OcrSystem.API.csproj -r linux-x64

COPY src/ src/
RUN dotnet publish src/OcrSystem.API/OcrSystem.API.csproj \
    -c Release -o /app/publish --no-restore -r linux-x64 --no-self-contained

# Stage 2 — runtime
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app

# Install Tesseract runtime and English language data
RUN apt-get update && apt-get install -y --no-install-recommends \
    libtesseract-dev \
    tesseract-ocr \
    tesseract-ocr-eng \
    libleptonica-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /app/publish .

# InteropDotNet (used by Tesseract NuGet) looks for native libs in /app/x64/.
# The NuGet package ships Windows DLLs there; add Linux .so symlinks alongside them.
# Also add libdl.so — on Debian 12 only libdl.so.2 exists; .NET P/Invoke looks in /app/ first.
RUN ln -sf /usr/lib/x86_64-linux-gnu/liblept.so.5       /app/x64/libleptonica-1.82.0.so && \
    ln -sf /usr/lib/x86_64-linux-gnu/libtesseract.so.5  /app/x64/libtesseract50.so && \
    ln -sf /usr/lib/x86_64-linux-gnu/libdl.so.2         /app/libdl.so

# Create directories for local file storage and Tesseract data
RUN mkdir -p /data/documents /data/tessdata && \
    cp /usr/share/tesseract-ocr/5/tessdata/eng.traineddata /data/tessdata/ 2>/dev/null || true

ENV LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:/app:/app/runtimes/linux-x64/native:$LD_LIBRARY_PATH
ENV ASPNETCORE_URLS=http://+:8080
ENV Tesseract__DataPath=/data/tessdata
ENV Storage__Type=local
ENV Storage__LocalPath=/data/documents

EXPOSE 8080
ENTRYPOINT ["dotnet", "OcrSystem.API.dll"]
